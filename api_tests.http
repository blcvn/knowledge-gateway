### KGS Platform API Tests
### Requires VSCode REST Client or IntelliJ HTTP Client
### Define variables for your environment:

@baseUrl = http://localhost:8000
# Run the "App Registry Service" requests in order to get these variables populated, 
# or paste them manually here if you already have them
@appId = <replace_with_app_id>
@apiKey = <replace_with_api_key>
@keyHash = <replace_with_key_hash>

# For Graph Service
@node1Id = <replace_with_source_node_id>
@node2Id = <replace_with_target_node_id>


### ============================================================================
### 1. App Registry Service
### ============================================================================

### 1.1 Create Application
# @name createApp
POST {{baseUrl}}/v1/apps
Content-Type: application/json

{
  "app_name": "Test Application",
  "description": "Application created by automated test script",
  "owner": "admin"
}


### 1.2 Get Application Details
# Make sure to replace appId or use the response from createApp
@appId = {{createApp.response.body.app_id}}
GET {{baseUrl}}/v1/apps/{{appId}}
Accept: application/json


### 1.3 List Applications
GET {{baseUrl}}/v1/apps
Accept: application/json


### 1.4 Issue API Key
# @name issueKey
POST {{baseUrl}}/v1/apps/{{appId}}/keys
Content-Type: application/json

{
  "name": "Test API Key",
  "scopes": "all",
  "ttl_seconds": 3600
}


### ============================================================================
### Set Authorization Header
### NOTE: Run issueKey first to populate these dynamically
### ============================================================================
@apiKey = {{issueKey.response.body.api_key}}
@keyHash = {{issueKey.response.body.key_hash}}


### ============================================================================
### 2. Ontology Service
### ============================================================================

### 2.1 Create Entity Type
POST {{baseUrl}}/v1/ontology/entities
Content-Type: application/json
Authorization: Bearer {{apiKey}}

{
  "name": "User",
  "description": "A system user",
  "schema": "{\"type\":\"object\",\"properties\":{\"username\":{\"type\":\"string\"},\"age\":{\"type\":\"integer\"}}}"
}


### 2.2 Create Relation Type
POST {{baseUrl}}/v1/ontology/relations
Content-Type: application/json
Authorization: Bearer {{apiKey}}

{
  "name": "FRIEND_OF",
  "description": "Represents a friendship between users",
  "properties_schema": "{\"type\":\"object\",\"properties\":{\"since_year\":{\"type\":\"integer\"}}}",
  "source_types": ["User"],
  "target_types": ["User"]
}


### ============================================================================
### 3. Graph Service
### ============================================================================

### 3.1 Create Source Node
# @name createSourceNode
POST {{baseUrl}}/v1/graph/nodes
Content-Type: application/json
Authorization: Bearer {{apiKey}}

{
  "label": "User",
  "properties_json": "{\"username\": \"alice123\", \"age\": 25}"
}

### 3.1 Create Target Node
# @name createTargetNode
POST {{baseUrl}}/v1/graph/nodes
Content-Type: application/json
Authorization: Bearer {{apiKey}}

{
  "label": "User",
  "properties_json": "{\"username\": \"bob456\", \"age\": 28}"
}

### Extracted Node IDs
@node1Id = {{createSourceNode.response.body.id}}
@node2Id = {{createTargetNode.response.body.id}}


### 3.2 Get Node
GET {{baseUrl}}/v1/graph/nodes/{{node1Id}}
Authorization: Bearer {{apiKey}}


### 3.3 Create Edge
POST {{baseUrl}}/v1/graph/edges
Content-Type: application/json
Authorization: Bearer {{apiKey}}

{
  "source_node_id": "{{node1Id}}",
  "target_node_id": "{{node2Id}}",
  "relation_type": "FRIEND_OF",
  "properties_json": "{\"since_year\": 2023}"
}


### 3.4 Get Context (Neighborhood)
GET {{baseUrl}}/v1/graph/nodes/{{node1Id}}/context?depth=1&direction=BOTH
Authorization: Bearer {{apiKey}}


### 3.5 Get Impact (Downstream)
GET {{baseUrl}}/v1/graph/nodes/{{node1Id}}/impact?max_depth=3
Authorization: Bearer {{apiKey}}


### 3.6 Get Coverage (Upstream)
GET {{baseUrl}}/v1/graph/nodes/{{node2Id}}/coverage
Authorization: Bearer {{apiKey}}


### ============================================================================
### 4. Rule Engine
### ============================================================================

### 4.1 Create Rule
POST {{baseUrl}}/v1/rules
Content-Type: application/json
Authorization: Bearer {{apiKey}}

{
  "name": "Auto-Friendship Enrichment",
  "description": "Automatically update friendship properties",
  "trigger_type": "SCHEDULED",
  "cron": "0 0 * * *",
  "cypher_query": "MATCH (a:User)-[r:FRIEND_OF]->(b:User) RETURN a,r,b",
  "action": "LOG",
  "payload_json": "{}"
}


### ============================================================================
### 5. Access Control
### ============================================================================

### 5.1 Create Policy
POST {{baseUrl}}/v1/policies
Content-Type: application/json
Authorization: Bearer {{apiKey}}

{
  "name": "Node Read Access",
  "description": "Allow reading nodes if user has read scope",
  "rego_content": "package kgs.authz\n\ndefault allow = false\n\nallow {\n  input.user.scopes[_] == \"read\"\n}"
}

### 5.2 List Policies
GET {{baseUrl}}/v1/policies
Authorization: Bearer {{apiKey}}


### ============================================================================
### Cleanup
### ============================================================================

### 1.5 Revoke API Key
DELETE {{baseUrl}}/v1/keys/{{keyHash}}
Authorization: Bearer {{apiKey}}
