# KGS Platform Docker Compose - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=kgs
POSTGRES_PASSWORD=kgspassword
POSTGRES_DB=kgs_platform

# -----------------------------------------------------------------------------
# Redis
# Leave REDIS_PASSWORD empty to disable authentication
# -----------------------------------------------------------------------------
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Neo4j (Graph Database)
# -----------------------------------------------------------------------------
NEO4J_PASSWORD=neo4jpassword
